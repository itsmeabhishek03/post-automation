# =============================================
# AI Content Automation - Environment Variables
# =============================================
# Copy this file to .env and fill in all values.

# ─── Server ──────────────────────────────────
PORT=3000

# ─── Gemini ──────────────────────────────────
GEMINI_API_KEY=AIzaSy...

# ─── Resend Email ────────────────────────────
# Get your API key at https://resend.com
RESEND_API_KEY=re_...
# "From" address must be verified with Resend (e.g. noreply@yourdomain.com)
RESEND_FROM_EMAIL=hello@myresumefit.tech
# (Optional) Reply-to address
RESEND_REPLY_TO_EMAIL=myresumefir.tech@gmail.com
# Admin who receives the generated post drafts
ADMIN_EMAIL=abhimishraop08@gmail.com

# ─── Scheduler ───────────────────────────────
# Cron schedule for post generation (default: 10 AM every 2 days)
# Format: "0 10 */2 * *"
CRON_SCHEDULE=0 10 */2 * *

# ─── Node Environment ────────────────────────
NODE_ENV=production
